{
  "mcpServers": {
    "vite-plus": {
      "command": "npx",
      "args": ["vp", "mcp"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm fix --skip=correctness/noUnusedImports"
          }
        ]
      }
    ]
  }
}
