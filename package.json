{
  "name": "vite-react-chakra-starter",
  "version": "0.1.0",
  "private": true,
  "author": "agustinusnathaniel",
  "type": "module",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "neverBuiltDependencies": [],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "serve": "vp preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "biome:ci": "biome ci",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "check:turbo": "pnpm turbo ultracite:check type:check test",
    "knip": "knip",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "vp config"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.30.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-devtools": "^0.8.2",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/react-router": "^1.139.12",
    "@tanstack/react-router-devtools": "^1.139.12",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@chakra-ui/cli": "^3.30.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@rolldown/plugin-babel": "^0.2.1",
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/router-plugin": "^1.139.12",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.6.0",
    "cross-env": "^10.1.0",
    "knip": "^5.70.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "5.9.3",
    "ultracite": "7.2.5",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plus": "latest",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
