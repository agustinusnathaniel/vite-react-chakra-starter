{
  "name": "vite-react-chakra-starter",
  "version": "0.1.0",
  "private": true,
  "author": "agustinusnathaniel",
  "type": "module",
  "engines": {
    "node": "^24.15.x"
  },
  "packageManager": "pnpm@11.8.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "serve": "vp preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "biome:ci": "biome ci",
    "turbo": "pnpm dlx turbo@2.6.1",
    "type:check": "tsc",
    "test": "vp test run",
    "test:ui": "vp test --ui --coverage",
    "test:coverage": "vp test --coverage run",
    "check:turbo": "pnpm turbo ultracite:check type:check test",
    "knip": "knip",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "release": "cross-env HUSKY=0 commit-and-tag-version",
    "push-release": "git push --follow-tags origin main",
    "prepare": "vp config"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-devtools": "^1.167.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@chakra-ui/cli": "^3.36.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@julr/vite-plugin-validate-env": "^2.2.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/router-plugin": "^1.168.22",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^13.0.0",
    "cross-env": "^10.1.0",
    "knip": "^6.27.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "6.0.3",
    "ultracite": "7.9.4",
    "vite": "catalog:",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  }
}
